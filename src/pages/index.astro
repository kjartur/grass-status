---
// Har du klippet gresset? — a one-question status page.
//
// HOW THE STATUS IS STORED
// -------------------------
// The only thing an admin ever edits is one date, as plain text (e.g. 2026-07-12).
// No JSON, no rebuild, no redeploy. The page works out "Ja." (mowed within the
// last 10 days) or "Nei." and the day-count entirely on its own, client-side,
// every time someone loads it. See README.md — it's a two-minute one-time setup.
//
// Styling lives in src/styles/global.css, the status logic lives in
// src/scripts/status.js, and the grass illustration lives in
// src/components/GrassField.astro — this file is just markup.
import '../styles/global.css';
import GrassField from '../components/GrassField.astro';

const GIST_RAW_URL = ''; // paste your gist's Raw text URL here — see README.md
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Har du klippet gresset?</title>
    <meta name="description" content="Status: er gresset klippet i det siste?" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&family=Oswald:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-gist-url={GIST_RAW_URL}>
    <div class="sky" aria-hidden="true">
      <div class="sky__sun"></div>
      <div class="cloud cloud--a"></div>
      <div class="cloud cloud--b"></div>
      <div class="cloud cloud--c"></div>
    </div>

    <div class="lawn" aria-hidden="true">
      <div class="lawn__stripes"></div>
      <div class="lawn__blades"></div>
      <div class="lawn__vignette"></div>
      <GrassField />
    </div>

    <main class="scene">
      <div class="sign">
        <div class="sign__plank">
          <div class="sign__grain" aria-hidden="true"></div>
          <span class="sign__bolt sign__bolt--tl"></span>
          <span class="sign__bolt sign__bolt--tr"></span>
          <div class="sign__panel">
            <p id="status-word" class="sign__status" data-state="loading">…</p>
            <p class="sign__caption">
              Antall dager siden gresset ble klippet:
              <span id="days-count" class="sign__days">–</span>
            </p>
          </div>
        </div>
        <div class="sign__stake" aria-hidden="true"></div>
        <GrassField class="lawn__foreground--overlay" viewBox="450 130 350 220" />
      </div>
    </main>

    <script src="../scripts/status.js"></script>
  </body>
</html>
