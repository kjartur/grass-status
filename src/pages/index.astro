        font-family: 'Oswald', system-ui, sans-serif;
        overflow-x: hidden;
      }

      /* ---------- Sky background ---------- */

      .sky {
        position: fixed;
        inset: 0;
        z-index: -1;
        background: linear-gradient(
          180deg,
          var(--sky-top) 0%,
          var(--sky-mid) 45%,
          var(--sky-horizon) 100%
