      }

      .sky__sun {
        position: absolute;
        top: 8%;
        right: 12%;
        width: clamp(140px, 20vw, 260px);
        height: clamp(140px, 20vw, 260px);
        border-radius: 50%;
        background: radial-gradient(
          circle,
          var(--sun-glow) 0%,
          rgba(255, 246, 221, 0.55) 35%,
          rgba(255, 246, 221, 0) 72%
        );
        filter: blur(2px);
      }

      .cloud {
        position: absolute;
        background: var(--cloud);
        border-radius: 50%;
        opacity: 0.9;
        filter: blur(6px);
      }

      .cloud::before,
      .cloud::after {
        content: '';
        position: absolute;
        background: var(--cloud);
        border-radius: 50%;
      }

      .cloud--a {
        top: 14%;
        left: 8%;
        width: 140px;
        height: 46px;
      }
      .cloud--a::before {
        width: 80px;
        height: 70px;
        top: -34px;
        left: 18px;
      }
      .cloud--a::after {
        width: 60px;
        height: 54px;
        top: -22px;
        left: 74px;
      }

      .cloud--b {
        top: 24%;
        left: 58%;
        width: 190px;
        height: 54px;
        opacity: 0.8;
      }
      .cloud--b::before {
        width: 100px;
        height: 84px;
        top: -40px;
        left: 26px;
      }
      .cloud--b::after {
        width: 70px;
        height: 60px;
        top: -24px;
        left: 108px;
      }

      .cloud--c {
        top: 10%;
        left: 34%;
        width: 100px;
        height: 34px;
        opacity: 0.65;
        transform: scale(0.8);
      }
      .cloud--c::before {
        width: 60px;
        height: 50px;
        top: -24px;
        left: 14px;
      }
      .cloud--c::after {
        width: 44px;
        height: 38px;
        top: -14px;
        left: 54px;
      }

      @media (prefers-reduced-motion: no-preference) {
        .cloud--a {
          animation: drift 90s linear infinite;
        }
        .cloud--b {
          animation: drift 130s linear infinite reverse;
        }
        .cloud--c {
          animation: drift 70s linear infinite;
        }
      }

      @keyframes drift {
        from {
          transform: translateX(0);
        }
        to {
          transform: translateX(60px);
        }
      }

      /* ---------- Lawn background ---------- */

      .lawn {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        height: 56vh;
        min-height: 320px;
        z-index: 0;
      }

      .lawn::before {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        top: -10vh;
        height: 10vh;
        background: linear-gradient(180deg, rgba(205, 234, 247, 0) 0%, var(--grass-stripe-light) 100%);
        z-index: 1;
      }

      .lawn__stripes {
        position: absolute;
        inset: 0;
        background-image: repeating-linear-gradient(
          100deg,
          var(--grass-stripe-dark) 0px,
          var(--grass-stripe-dark) 90px,
          var(--grass-stripe-light) 90px,
          var(--grass-stripe-light) 180px
        );
      }

      .lawn__blades {
        position: absolute;
        inset: 0;
        opacity: 0.55;
        background-image: repeating-linear-gradient(
            95deg,
            rgba(93, 143, 60, 0.35) 0px,
            transparent 2px,
            transparent 7px
          ),
          repeating-linear-gradient(
            85deg,
            rgba(30, 58, 30, 0.4) 0px,
            transparent 2px,
            transparent 9px
          );
        mix-blend-mode: soft-light;
      }

      .lawn__vignette {
        position: absolute;
        inset: 0;
        background: radial-gradient(
          ellipse at 50% 38%,
          rgba(0, 0, 0, 0) 0%,
          rgba(0, 0, 0, 0.12) 55%,
          rgba(10, 20, 8, 0.55) 100%
        );
      }

      .lawn__foreground {
        position: absolute;
        left: 0;
        right: 0;
        bottom: -10px;
        width: 100%;
        height: 46vh;
        min-height: 280px;
        max-height: 480px;
        filter: blur(1.5px);
        -webkit-mask-image: linear-gradient(
          to bottom,
          transparent 0%,
          rgba(0, 0, 0, 0.5) 12%,
          black 30%
        );
        mask-image: linear-gradient(
          to bottom,
          transparent 0%,
          rgba(0, 0, 0, 0.5) 12%,
          black 30%
        );
      }

      .blade-layer path {
        fill: none;
        stroke-linecap: round;
        transform-box: fill-box;
        transform-origin: bottom center;
      }

      .blade-layer--back path {
        stroke: #21421f;
        stroke-width: 7;
        opacity: 0.55;
      }

      .blade-layer--mid path {
        stroke: var(--grass-mid);
        stroke-width: 9;
        opacity: 0.75;
      }

      .blade-layer--front path {
        stroke: var(--grass-light);
        stroke-width: 11;
        opacity: 0.95;
      }

      .blade-layer--back {
        filter: blur(1.5px);
      }

      .blade-layer--front path:nth-child(3n + 1) {
        stroke: #74a84a;
      }

      @media (prefers-reduced-motion: no-preference) {
        .blade-layer path {
          animation: sway 5s ease-in-out infinite;
        }
        .blade-layer path:nth-child(2n) {
          animation-duration: 6.1s;
          animation-delay: -1.6s;
        }
        .blade-layer path:nth-child(3n) {
          animation-duration: 4.3s;
          animation-delay: -2.4s;
        }
        .blade-layer path:nth-child(5n) {
          animation-duration: 5.7s;
          animation-delay: -0.8s;
        }
        .blade-layer--back path {
          animation-duration: 7s;
        }
      }

      @keyframes sway {
        0%,
        100% {
          transform: rotate(-1.6deg);
        }
        50% {
          transform: rotate(2deg);
        }
      }

      /* ---------- Sign ---------- */

      .scene {
